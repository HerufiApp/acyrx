# Copy this file to `.env` and fill in the keys you have.
# Real environment variables take precedence over values in `.env`.
# `.env` is gitignored — your keys are never committed.

# Your own provider keys (used by the agent).
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: upgrades web-search quality.
TAVILY_API_KEY=

# Supabase authentication. When both are set, users must sign in before the
# AI features (chat, inline edit, autocomplete, commit-message/diff explain)
# can be used. Leave blank to disable the auth gate.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: built-in ("ours") fallback keys, used only when no user key above is set.
ACYRX_GEMINI_KEY=
ACYRX_ANTHROPIC_KEY=
